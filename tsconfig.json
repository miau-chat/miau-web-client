{
	"compilerOptions": {
		"types": [
			"vite/client"
		],
		"outDir": "./dist/",
		"module": "ESNext",
		"target": "es2022",
		"allowJs": true,
		"strict": true,
		"rootDir": "./src/",
		"lib": [
			"ESNext",
			"DOM",
			"ES5"
		],
		"moduleResolution": "Bundler",
		"strictPropertyInitialization": false,
	},
	"watchOptions": {
		"excludeDirectories": [
			"**/node_modules",
		]
	},
	"include": [
		"src/**/*",
	],
	"exclude": [
		"node_modules"
	]
}